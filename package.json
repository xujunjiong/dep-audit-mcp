{
  "name": "dep-audit-mcp",
  "version": "1.0.0",
  "description": "MCP Server for npm dependency security audit using npm audit",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "dep-audit-mcp": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node build/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "npm",
    "audit",
    "security",
    "dependency",
    "vulnerability"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
